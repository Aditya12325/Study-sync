# Firebase Admin Service Account Credentials (JSON string)
# Get this from Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_SECRET='{
  "type": "service_account",
  "project_id": "your-firebase-project",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "..."
}'

# Firebase Web Client API Key (string)
# Get this from Firebase Console -> Project Settings -> General -> Web API Key
FIREBASE_WEB_API_KEY="AIzaSyYourFirebaseWebApiKeyHere"

# Groq API Key (string)
# Get this from https://console.groq.com/keys
GROQ_API_KEY="gsk_YourGroqApiKeyHere"
